# Required for PDF extraction (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Model for structured extraction and optional biomarker fallback
CLAUDE_MODEL=claude-sonnet-4-20250514

# PDF limits (text-based reports only; see README)
MAX_PDF_MB=10
# Alternative: exact byte cap instead of MAX_PDF_MB
# MAX_PDF_SIZE_BYTES=10485760
MAX_PDF_PAGES=100

# Optional: biomarker matching LLM fallback (0 disables)
BIOMARKER_LLM_FALLBACK=1
BIOMARKER_FALLBACK_TOP_K=25

# Runtime JSON directory (biomarkers.json, translations.json, ranges.json, unit_conversions.json)
BLOODSCOPE_DATA_DIR=data
